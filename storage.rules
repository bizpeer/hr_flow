rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function getUserProfile() {
      return firestore.get(/databases/(default)/documents/UserProfile/$(request.auth.uid));
    }

    function getUserData() {
      let profile = getUserProfile();
      return profile != null ? profile.data : null;
    }

    function isSuperAdmin() {
      let data = getUserData();
      return isAuthenticated() && data != null && data.role == 'SUPER_ADMIN';
    }

    // 특정 회사의 관리자인지 확인
    function isCompanyAdmin(companyId) {
      let data = getUserData();
      return isAuthenticated() && data != null && 
             data.companyId == companyId && 
             (data.role == 'ADMIN' || data.role == 'SUB_ADMIN');
    }

    // 지출결의 전용 경로: /companies/{companyId}/expenses/{userId}/...
    match /companies/{companyId}/expenses/{userId}/{allPaths=**} {
      // 본인이거나, 해당 회사의 관리자/슈퍼어드민이면 허용
      allow read, write: if isAuthenticated() && (
        request.auth.uid == userId || 
        isCompanyAdmin(companyId) ||
        isSuperAdmin()
      );
    }

    // 일반 회사 경로
    match /companies/{companyId}/{allPaths=**} {
      allow read, write: if isAuthenticated() && (
        isSuperAdmin() || 
        (getUserData() != null && getUserData().companyId == companyId)
      );
    }
    
    match /{allPaths=**} {
      allow read, write: if isSuperAdmin();
    }
  }
}
